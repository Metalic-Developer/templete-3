//////////////////// ENUMS ////////////////////

enum Role {
  PLAYER
  OWNER
  EMPLOYEE
  ADMIN
}

enum SkillLevel {
  WEAK
  AVERAGE
  GOOD
  EXCELLENT
  LEGENDARY
}

enum FieldType {
  FOOTBALL
  PADEL
  TENNIS
  BASKETBALL
  SWIMMING
}

enum FieldStatus {
  OPEN
  CLOSED
  MAINTENANCE
}

enum SlotStatus {
  AVAILABLE
  TEMP_LOCKED
  BOOKED
  UNAVAILABLE
  AVAILABLE_NEEDS_CONFIRM  // ⬅️ أضف هذه القيمة
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  FAILED
  EXPIRED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  SYSTEM
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_EXPIRED  // ⬅️ أضف هذه القيمة
  PAYMENT_SUCCESS
  PAYMENT_FAILED
}

enum ErrorCode {
  // Auth Errors
  AUTHENTICATION_ERROR  // ⬅️ أضف هذه القيمة
  UNAUTHORIZED
  INVALID_CREDENTIALS
  SESSION_EXPIRED
  
  // Validation Errors
  VALIDATION_ERROR
  INVALID_INPUT
  MISSING_REQUIRED_FIELD
  
  // Booking Errors
  BOOKING_NOT_FOUND
  BOOKING_CONFLICT
  SLOT_UNAVAILABLE
  SLOT_ALREADY_BOOKED
  SLOT_NOT_FOUND
  SLOT_LOCKED_BY_OTHER
  
  // Payment Errors
  PAYMENT_FAILED
  PAYMENT_GATEWAY_ERROR  // ⬅️ أضف هذه القيمة
  INVALID_PAYMENT_TRANSITION  // ⬅️ أضف هذه القيمة
  
  // Field Errors
  FIELD_NOT_FOUND
  FIELD_CLOSED
  FIELD_MAINTENANCE
  
  // Concurrency & System
  CONCURRENT_MODIFICATION  // ⬅️ أضف هذه القيمة
  SERVICE_UNAVAILABLE
  INTERNAL_SERVER_ERROR
  
  // Rate Limiting
  RATE_LIMITED
}

//////////////////// USER ////////////////////

model User {
  // === Primary Keys ===
  id String @id @default(cuid())

  // === Basic Information ===
  name         String
  email        String    @unique
  passwordHash String?
  phoneNumber  String?   @unique
  age  DateTime? 
  
  // === Profile ===
  avatarUrl    String?
  description  String?    @db.Text
  
  // === Skills ===
  skillLevel         SkillLevel @default(AVERAGE)
  preferredPositions String[]
  
  // === Permissions ===
  role Role @default(PLAYER)
  
  // === Verification & Activity ===
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLogin   DateTime? // ⬅️ تصحيح الاسم
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Relations ===
  slotsLocked     Slot[]           @relation("SlotLockedByUser")
  payments        Payment[]
  bookings        Booking[]
  notifications   Notification[]
  reviews         Review[]
  idempotencyKeys IdempotencyKey[]
  auditLogs       AuditLog[]
  flaggedUsers    FlaggedUser[]
  
  // === Indexes ===
  @@index([email])
  @@index([role, isActive])
  @@index([createdAt])
  @@map("users")
}

//////////////////// FIELD ////////////////////

model Field {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Basic Information ===
  name        String
  description String? @db.Text
  location    String
  address     String
  
  // === Type & Images ===
  type      FieldType
  imageUrls String[] // ⬅️ استخدام مصفوفة بدلاً من string واحدة
  
  // === Pricing ===
  pricePerHour Decimal @db.Decimal(10, 2)
  depositPrice Decimal @default(0) @db.Decimal(10, 2)
  currency     String  @default("EGP")
  
  // === Schedule ===
  openingTime         String @default("08:00")
  closingTime         String @default("22:00")
  slotDurationMin Int    @default(60) 
  
  // === Status & Facilities ===
  status     FieldStatus @default(OPEN)
  facilities String[]
  capacity   Int?
  
  // === Rules ===
  rules String[] // ⬅️ إضافة حقل القواعد
  
  // === Owner ===
  ownerId String?
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Relations ===
  slots    Slot[]
  bookings Booking[]
  reviews  Review[]
  
  // === Indexes ===
  @@index([location])
  @@index([type, status])
  @@index([pricePerHour])
  @@map("fields")
}

//////////////////// SLOT ////////////////////

model Slot {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Field Relation ===
  fieldId String
  field   Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  
  // === Timing ===
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int      @default(60)
  
  // === Pricing ===
  price   Decimal @db.Decimal(10, 2)
  deposit Decimal @default(0) @db.Decimal(10, 2)
  
  // === Status & Locking ===
  status      SlotStatus @default(AVAILABLE)
  lockedUntil DateTime?
  lockedById  String?
  lockedBy    User?      @relation("SlotLockedByUser", fields: [lockedById], references: [id], onDelete: SetNull)
  
  // === Additional Data ===
  isPeakHour Boolean @default(false)
  discount   Decimal @default(0) @db.Decimal(5, 2)
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Relations ===
  bookings Booking[]
  
  // === Constraints & Indexes ===
  @@unique([fieldId, startTime])
  @@index([status, lockedUntil])
  @@index([startTime, endTime])
  @@index([fieldId, status])
  @@map("slots")
}

//////////////////// BOOKING ////////////////////

model Booking {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Relations ===
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fieldId String
  field   Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  
  slotId String
  slot   Slot   @relation(fields: [slotId], references: [id], onDelete: Cascade)
  
  // === Status ===
  status        BookingStatus @default(DRAFT)
  paymentStatus PaymentStatus @default(PENDING)
  
  // === Pricing ===
  totalAmount Decimal @db.Decimal(10, 2)
  amountPaid  Decimal @default(0) @db.Decimal(10, 2)
  depositPaid Decimal @default(0) @db.Decimal(10, 2)
  
  // === Order Information ===
  orderId   String? @unique
  paymentId String? @unique
  
  // === Timing ===
  expiresAt   DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?
  
  // === Idempotency ===
  idempotencyKey String? @unique
  ipAddress      String?
  userAgent      String?
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Relations ===
  payments      Payment[]
  notifications Notification[]
  reviews       Review[]
  
  // === Indexes ===
  @@index([userId, status])
  @@index([slotId, status])
  @@index([orderId])
  @@index([expiresAt])
  @@map("bookings")
}

//////////////////// PAYMENT ////////////////////

model Payment {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Relations ===
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // === Amount ===
  amount    Decimal @db.Decimal(10, 2)
  currency  String  @default("EGP")
  feeAmount Decimal @default(0) @db.Decimal(10, 2)
  netAmount Decimal @db.Decimal(10, 2)
  
  // === Payment Information ===
  gateway   String  @default("paymob")
  
  // === Provider Information ===
  providerOrderId       String? @unique
  providerTransactionId String? @unique
  internalOrderId       String? @unique
  
  // === Optimistic Locking ===
  version Int @default(0)
  
  // === Webhook Tracking ===
  webhookProcessedAt DateTime?
  webhookAttempts    Int       @default(0)
  
  // === Status ===
  status         PaymentStatus @default(PENDING)
  refundedAmount Decimal       @default(0) @db.Decimal(10, 2)
  
  // === Additional Data ===
  metadata     Json?
  receiptUrl   String?
  errorMessage String?
  
  // === Timestamps ===
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  paidAt     DateTime?
  refundedAt DateTime?
  
  // === Relations ===
  webhookProcessings WebhookProcessing[]
  
  // === Indexes ===
  @@index([bookingId])
  @@index([userId])
  @@index([providerOrderId])
  @@index([providerTransactionId])
  @@index([status, createdAt])
  @@map("payments")
}

//////////////////// WEBHOOK PROCESSING ////////////////////

model WebhookProcessing {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Unique Key ===
  providerOrderId       String  @unique
  providerTransactionId String?
  
  // === Processing Information ===
  processedAt   DateTime  @default(now())
  status        String // 'PROCESSING', 'SUCCESS', 'FAILED'
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  errorMessage  String?
  
  // === Relations ===
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Indexes ===
  @@index([providerOrderId])
  @@index([processedAt])
  @@index([status])
  @@map("webhook_processings")
}

//////////////////// NOTIFICATION ////////////////////

model Notification {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Relations ===
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  // === Content ===
  type    NotificationType
  title   String
  message String           @db.Text
  data    Json?
  
  // === Status ===
  isRead Boolean  @default(false)
  isSent Boolean  @default(true)
  sentAt DateTime @default(now())
  
  // === Channels ===
  sentVia String[]
  
  // === Timestamps ===
  createdAt DateTime  @default(now())
  readAt    DateTime?
  
  // === Indexes ===
  @@index([userId, isRead])
  @@index([bookingId])
  @@index([type, createdAt])
  @@map("notifications")
}

//////////////////// REVIEW ////////////////////

model Review {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Relations ===
  fieldId String
  field   Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  // === Review Content ===
  rating  Int     @default(5)
  title   String?
  comment String? @db.Text
  
  // === Verification ===
  isVerified   Boolean @default(false)
  helpfulVotes Int     @default(0)
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Constraints & Indexes ===
  @@unique([fieldId, userId, bookingId])
  @@index([fieldId, rating])
  @@index([userId])
  @@index([createdAt])
  @@map("reviews")
}

//////////////////// IDEMPOTENCY KEY ////////////////////

model IdempotencyKey {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === Key & User ===
  key    String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // === Request Information ===
  requestHash String
  method      String
  path        String // ⬅️ تأكد من وجود هذا الحقل
  response    Json?
  
  // === Expiration ===
  expiresAt DateTime
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Constraints ===
  @@unique([key, userId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

//////////////////// AUDIT LOG ////////////////////

model AuditLog {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === User ===
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // === Action ===
  action     String
  entityType String?
  entityId   String?
  
  // === Changes ===
  oldData Json?
  newData Json?
  
  // === Request Information ===
  ipAddress String?
  userAgent String?
  endpoint  String?
  
  // === Result ===
  success      Boolean @default(true)
  errorMessage String?
  
  // === Timestamp ===
  createdAt DateTime @default(now())
  
  // === Indexes ===
  @@index([userId, createdAt])
  @@index([action, entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

//////////////////// FLAGGED USER ////////////////////

model FlaggedUser {
  // === Primary Keys ===
  id String @id @default(cuid())
  
  // === User ===
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // === Details ===
  reason   String @db.Text
  category String
  severity String @default("MEDIUM")
  
  // === Resolution ===
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?   @db.Text
  
  // === Expiration ===
  expiresAt DateTime?
  
  // === Timestamps ===
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // === Indexes ===
  @@index([userId, resolved])
  @@index([severity, createdAt])
  @@map("flagged_users")
}
// lib/shared/rate-limit/index.ts
export class RateLimitService {
  private requests = new Map<string, { count: number; resetTime: number }>();

  check(key: string, limit: number, windowMs: number): boolean {
    const now = Date.now();
    const record = this.requests.get(key);

    if (!record || now > record.resetTime) {
      // New window
      this.requests.set(key, {
        count: 1,
        resetTime: now + windowMs
      });
      return true;
    }

    if (record.count >= limit) {
      return false;
    }

    record.count++;
    return true;
  }
}


export const rateLimitService = new RateLimitService();
