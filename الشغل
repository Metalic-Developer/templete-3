    } catch (error: any) {
      paymentLogger.error({ 
        msg: 'Error creating Paymob order',
        error: error.message,
        bookingId,
        amount,
        response: error.response?.data 
      })
      throw error
    }
  }

  // 3. إنشاء Payment Key لفتح Iframe
  async getPaymentKey({
    orderId,
    amount,
    billingData,
    bookingId
  }: {
    orderId: string | number
    amount: number
    billingData: PaymobBillingData
    bookingId: string
  }): Promise<string> {
    try {
      const authToken = await this.getAuthToken()
      
      paymentLogger.info({ 
        msg: 'Getting Paymob payment key',
        orderId, 
        bookingId 
      })
      
      const response = await axios.post(
        `${PAYMOB_BASE_URL}/acceptance/payment_keys`,
        {
          auth_token: authToken,
          amount_cents: Math.round(amount * 100),
          expiration: 3600,
          order_id: orderId,
          billing_data: billingData,
          currency: 'EGP',
          integration_id: this.integrationId,
          lock_order_when_paid: 'false',
          extra: {
            booking_id: bookingId,
            timestamp: Date.now()
          }
        },
        { 
          timeout: 10000,
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${authToken}`
          }
        }
      )

      paymentLogger.info({ 
        msg: 'Paymob payment key received',
        orderId,
        tokenLength: response.data.token?.length 
      })
      return response.data.token
    } catch (error: any) {
      paymentLogger.error({ 
        msg: 'Error getting Paymob payment key',
        error: error.message,
        orderId,
        response: error.response?.data 
      })
      throw error
    }
  }

  // 4. التحقق من صحة الـ HMAC (لـ Webhook) - إصدار محسن
  verifyHMAC(data: any, receivedHMAC: string): boolean {
    try {
      // 🔴 إصلاح: استخدام دالة موحدة للتحقق
      const calculatedHMAC = this.calculateHMAC(data)
      
      // 🔴 إصلاح مشكلة Buffer
      const isEqual = this.safeHMACCompare(calculatedHMAC, receivedHMAC)
      
      paymentLogger.info({ 
        msg: 'HMAC verification completed',
        isEqual,
        orderId: data.order?.id,
        method: 'paymob-service'
      })
      
      return isEqual
    } catch (error: any) {
      paymentLogger.error({ 
        msg: 'HMAC verification error',
        error: error.message,
        dataKeys: Object.keys(data).join(',')
      })
      return false
    }
  }

  // 🔴 إضافة: دالة آمنة للمقارنة
  private safeHMACCompare(expected: string, actual: string): boolean {
    try {
      // طريقة بسيطة لتجنب مشكلة Buffer
      if (expected.length !== actual.length) {
        return false
      }
      
      let result = 0
      for (let i = 0; i < expected.length; i++) {
        result |= expected.charCodeAt(i) ^ actual.charCodeAt(i)
      }
      return result === 0
    } catch {
      return false
    }
  }

  // 🔴 إضافة: دالة محسنة لحساب HMAC
  private calculateHMAC(data: any): string {
    const hmacString = this.HMAC_FIELDS_ORDER
      .map(field => {
        if (field === 'order') {
          return data.order?.id || ''
        }
        if (field === 'source_data') {
          const source = data.source_data || {}
          return `${source.pan || ''}${source.sub_type || ''}${source.type || ''}`
        }
        return data[field] || ''
      })
      .join('')
    
    return crypto
      .createHmac('sha512', this.hmacSecret)
      .update(hmacString)
      .digest('hex')
  }

  // 🔴 إضافة: تحقق من timestamp
  validateWebhookTimestamp(createdAt: string): { isValid: boolean; date: Date | null } {
    try {
      // محاولة تحويل التاريخ بأكثر من طريقة
      let date: Date
      
      if (createdAt.includes('T')) {
        // ISO format
        date = new Date(createdAt)
      } else if (createdAt.includes(' ')) {
        // Paymob format: "2024-01-15 12:33:22"
        const [datePart, timePart] = createdAt.split(' ')
        date = new Date(`${datePart}T${timePart}`)
      } else {
        date = new Date(createdAt)
      }

      const isValid = !isNaN(date.getTime())
      
      paymentLogger.debug({
        msg: 'Webhook timestamp validation',
        input: createdAt,
        parsed: date.toISOString(),
        isValid
      })

      return { isValid, date: isValid ? date : null }
    } catch (error: any) {
      paymentLogger.warn({
        msg: 'Failed to parse webhook timestamp',
        input: createdAt,
        error: error.message
      })
      return { isValid: false, date: null }
    }
  }

  // 5. Mock mode للتنمية
  isMockMode(): boolean {
    return ENV.NODE_ENV !== 'production' || !this.apiKey
  }

  // 6. إنشاء order وهمي للتنمية
  async createMockOrder(params: {
    amount: number
    currency: string
    bookingId: string
  }): Promise<PaymobOrder> {
    paymentLogger.info({ 
      msg: 'Creating mock Paymob order',
      ...params 
    })
    
    return {
      id: Math.floor(Math.random() * 1000000),
      amount_cents: params.amount * 100,
      currency: params.currency,
      merchant_order_id: params.bookingId
    }
  }

  // 7. مفتاح دفع وهمي للتنمية
  async getMockPaymentKey(params: {
    orderId: number
  }): Promise<string> {
    paymentLogger.info({ 
      msg: 'Creating mock payment key',
      ...params 
    })
    return `mock_token_${Date.now()}_${params.orderId}`
  }

  // 🔴 إضافة: دالة مساعدة لتحويل التاريخ
  static parsePaymobDate(dateString: string): Date | null {
    try {
      if (!dateString) return null
      
      // محاولة ISO أولاً
      const isoDate = new Date(dateString)
      if (!isNaN(isoDate.getTime())) return isoDate
      
      // محاولة Paymob format
      if (dateString.includes(' ')) {
        const [datePart, timePart] = dateString.split(' ')
        const paymobDate = new Date(`${datePart}T${timePart}`)
        if (!isNaN(paymobDate.getTime())) return paymobDate
      }
      
      return null
    } catch {
      return null
    }
  }
}

