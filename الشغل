export class BookingOrchestrator {
  /**
   * 🎫 1. إنشاء حجز جديد - مع إصلاح Race Condition
   */
  static async createBooking(input: BookingCreateInput): Promise<BookingCreateResult> {
    const startTime = Date.now()
    const requestId = `booking_create_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

    bookingLogger.info({
      msg: 'Creating booking',
      requestId,
      userId: input.userId,
      slotId: input.slotId,
      fieldId: input.fieldId,
      idempotencyKey: input.idempotencyKey
    })

    try {
      // 🔐 Idempotency check
      if (input.idempotencyKey) {
        const check = await IdempotencyGuard.check(
          input.idempotencyKey,
          input.userId,
          'booking:create',
          { slotId: input.slotId, fieldId: input.fieldId }
        )

        if (!check.shouldProceed) {
          if (check.response) {
            bookingLogger.info({
              msg: 'Idempotent response returned',
              requestId
            })
            return check.response as BookingCreateResult
          }
          throw new DomainError('BOOKING_IN_PROGRESS', 'جاري معالجة الطلب')
        }
      }

      const result = await prisma.$transaction(async (tx: any) => {
        // 🔴 إصلاح: استخدام findFirst بدل findUnique مع الشروط المركبة
        const slot = await tx.slot.findFirst({
          where: {
            id: input.slotId,
            fieldId: input.fieldId,
            status: SLOT_STATUS.TEMP_LOCKED,
            lockedById: input.userId,
            lockedUntil: { gt: new Date() }
          },
          include: { field: true }
        })

        if (!slot) {
          throw new DomainError('SLOT_NOT_FOUND', 'الموعد لم يعد متاحاً أو انتهى قفله')
        }

        // 🔴 إضافة: إعادة قفل الـ Slot لتجنب فجوة زمنية
        await tx.slot.update({
          where: { id: slot.id },
          data: {
            lockedUntil: new Date(Date.now() + 15 * 60 * 1000)
          }
        })

        // 2. 📏 تحقق من حدود الحجز
        await checkBookingLimits({
          userId: input.userId,
          slotDate: new Date(slot.startTime),
          slotDurationMin: slot.durationMinutes || 60
        })

        // 3. 🎫 إنشاء Booking
        const booking = await tx.booking.create({
          data: {
            userId: input.userId,
            fieldId: input.fieldId,
            slotId: input.slotId,
            status: BOOKING_STATUS.DRAFT,
            paymentStatus: PAYMENT_STATUS.PENDING,
            totalAmount: slot.price,
            expiresAt: addMinutes(new Date(), 10),
            idempotencyKey: input.idempotencyKey || null
          }
        })

        const result: BookingCreateResult = {
          bookingId: booking.id,
          needsConfirmation: !this.canBookDirectly(new Date(slot.startTime))
        }

        // 💾 حفظ للـ Idempotency
        if (input.idempotencyKey) {
          await IdempotencyGuard.saveResponse(
            input.idempotencyKey,
            input.userId,
            'booking:create',
            result,
            { slotId: input.slotId, fieldId: input.fieldId },
            60
          )
        }

        bookingLogger.info({
          msg: 'Booking created successfully',
          requestId,
          bookingId: booking.id,
          durationMs: Date.now() - startTime
        })

        return result
      }, {
        isolationLevel: 'Serializable',
        maxWait: 5000,
        timeout: 10000
      })

      return result

    } catch (error: any) {
      bookingLogger.error({
        msg: 'Booking creation failed',
        requestId,
        error: error.message,
        userId: input.userId,
        durationMs: Date.now() - startTime
      })
      
      if (error instanceof DomainError) {
        throw error
      }
      throw new DomainError('INTERNAL_ERROR', 'فشل في إنشاء الحجز')
    }
  }

  /**
   * 💳 2. بدء عملية الدفع - مع فصل Side Effects
   */
  static async initiatePayment(input: PaymentInitInput & { userId: string }): Promise<PaymentInitResult> {
    const startTime = Date.now()
    const requestId = `payment_init_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

    bookingLogger.info({
      msg: 'Initiating payment',
      requestId,
      bookingId: input.bookingId,
      userId: input.userId,
      amount: input.amount
    })

    try {
      // 🔴 1. التحقق باستخدام المصدر الوحيد للحقيقة
      const { booking } = await PaymentStateGuard.assertCanProcessPayment({
        bookingId: input.bookingId,
        userId: input.userId
      })

      // 🔴 2. Idempotency check أولاً
      const idempotencyKey = input.idempotencyKey || IdempotencyGuard.generateKey('payment')
      
      const check = await IdempotencyGuard.check(
        idempotencyKey,
        input.userId,
        'payment:initiate',
        { bookingId: input.bookingId, amount: input.amount }
      )

      if (!check.shouldProceed) {
        if (check.response) {
          bookingLogger.info({
            msg: 'Idempotent payment response',
            requestId
          })
          return check.response as PaymentInitResult
        }
        throw new DomainError('BOOKING_IN_PROGRESS')
      }

      // 🔴 3. Database Transaction فقط (بدون side effects)
      const transactionResult = await prisma.$transaction(async (tx: any) => {
        // تجديد قفل الـ Slot داخل الـ Transaction
        await tx.slot.update({
          where: { id: booking.slotId },
          data: {
            lockedUntil: new Date(Date.now() + 20 * 60 * 1000)
          }
        })

        // إنشاء Payment في Database فقط
        const payment = await tx.payment.create({
          data: {
            bookingId: input.bookingId,
            amount: input.amount,
            currency: input.currency || 'EGP',
            internalOrderId: `pay_${booking.id}_${Date.now()}_${Math.random().toString(36).substr(2, 6)}`,
            status: PAYMENT_STATUS.PROCESSING,
            version: 0,
            userId: input.userId
          }
        })

        // تحديث Booking في Database فقط
        await tx.booking.update({
          where: { id: input.bookingId },
          data: {
            status: BOOKING_STATUS.PENDING_PAYMENT,
            paymentStatus: PAYMENT_STATUS.PROCESSING,
            paymentId: payment.id,
            expiresAt: new Date(Date.now() + 30 * 60 * 1000)
          }
        })

        return { payment, idempotencyKey }
      }, {
        isolationLevel: 'RepeatableRead',
        maxWait: 5000,
        timeout: 10000
      })

      // 🔴 4. Side Effects بعد نجاح الـ Transaction
      let providerOrderId: string = ''
      let paymentToken: string = ''

      try {
        // 📞 استدعاء Paymob API
        if (paymobService.isMockMode()) {
          const mockOrder = await paymobService.createMockOrder({
            amount: input.amount,
            currency: input.currency || 'EGP',
            bookingId: input.bookingId
          })
          providerOrderId = `mock_${mockOrder.id}`
          paymentToken = await paymobService.getMockPaymentKey({ orderId: mockOrder.id })
        } else {
          const order = await paymobService.createOrder({
            amount: input.amount,
            currency: input.currency || 'EGP',
            bookingId: input.bookingId,
            userId: input.userId
          })
          providerOrderId = order.id.toString()
          
          const billingData = {
            apartment: "NA",
            email: booking.user.email,
            floor: "NA",
            first_name: booking.user.name?.split(' ')[0] || "عميل",
            street: "NA",
            building: "NA",
            phone_number: booking.user.phoneNumber || "01000000000",
            shipping_method: "NA",
            postal_code: "NA",
            city: "NA",
            country: "NA",
            last_name: booking.user.name?.split(' ').slice(1).join(' ') || "مستخدم",
            state: "NA"
          }

          paymentToken = await paymobService.getPaymentKey({
            orderId: order.id,
            amount: input.amount,
            billingData,
            bookingId: input.bookingId
          })
        }

        // 🔄 تحديث Payment بـ providerOrderId خارج الـ Transaction
        await prisma.payment.update({
          where: { id: transactionResult.payment.id },
          data: { providerOrderId }
        })

      } catch (paymentApiError: any) {
        // إذا فشلت API الدفع، نرجع Payment للـ PENDING
        await prisma.payment.update({
          where: { id: transactionResult.payment.id },
          data: { 
            status: PAYMENT_STATUS.FAILED,
            errorMessage: paymentApiError.message
          }
        })
        
        throw new DomainError('PAYMENT_GATEWAY_ERROR', 'فشل في الاتصال بخدمة الدفع')
      }

      // 🔴 5. إعداد النتيجة
      const result: PaymentInitResult = {
        paymentUrl: paymobService.isMockMode() 
          ? `/payment/mock/${providerOrderId}` 
          : `https://accept.paymob.com/api/acceptance/iframes/ ${ENV.PAYMOB_IFRAME_ID || 'default'}?payment_token=${paymentToken}`,
        orderId: providerOrderId,
        idempotencyKey: transactionResult.idempotencyKey,
        internalPaymentId: transactionResult.payment.id
      }

      // 🔴 6. حفظ Idempotency خارج الـ Transaction
      await IdempotencyGuard.saveResponse(
        transactionResult.idempotencyKey,
        input.userId,
        'payment:initiate',
        result,
        { bookingId: input.bookingId, amount: input.amount },
        30
      )

      bookingLogger.info({
        msg: 'Payment initiated successfully',
        requestId,
        internalPaymentId: transactionResult.payment.id,
        providerOrderId,
        durationMs: Date.now() - startTime
      })

      return result

    } catch (error: any) {
      bookingLogger.error({
        msg: 'Payment initiation failed',
        requestId,
        error: error.message,
        bookingId: input.bookingId,
        durationMs: Date.now() - startTime
      })
      
      if (error instanceof DomainError) {
        throw error
      }
      throw new DomainError('INTERNAL_ERROR', 'فشل في بدء عملية الدفع')
    }
  }

  /**
   * ✅ 3. إكمال الحجز بعد الدفع - مع فصل Side Effects
   */
  static async completeBooking(params: {
    bookingId: string
    success: boolean
    paymentDetails: {
      transactionId: string
      orderId: string
      amount: number
      currency: string
    }
  }) {
    const startTime = Date.now()
    const requestId = `complete_booking_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

    bookingLogger.info({
      msg: 'Completing booking',
      requestId,
      bookingId: params.bookingId,
      success: params.success,
      orderId: params.paymentDetails.orderId
    })

    try {
      // 🔴 1. Webhook Idempotency Check
      const webhookCheck = await WebhookIdempotencyService.beginProcessing({
        providerOrderId: params.paymentDetails.orderId,
        providerTransactionId: params.paymentDetails.transactionId
      })

      if (!webhookCheck.shouldProcess && webhookCheck.existingRecord?.paymentId) {
        bookingLogger.info({
          msg: 'Webhook already processed',
          requestId,
          providerOrderId: params.paymentDetails.orderId,
          existingPaymentId: webhookCheck.existingRecord.paymentId
        })
        return { success: true, paymentId: webhookCheck.existingRecord.paymentId }
      }

      // 🔴 2. التحقق باستخدام المصدر الوحيد للحقيقة
      const payment = await PaymentStateGuard.assertWebhookValid({
        providerOrderId: params.paymentDetails.orderId,
        transactionId: params.paymentDetails.transactionId,
        amount: params.paymentDetails.amount
      })

      // 🔴 3. Database Transaction فقط
      const transactionResult = await prisma.$transaction(async (tx: any) => {
        if (params.success) {
          // ✅ نجاح الدفع مع Optimistic Locking
          const updatedPayment = await tx.payment.update({
            where: { 
              id: payment.id,
              version: payment.version
            },
            data: {
              status: PAYMENT_STATUS.PAID,
              providerTransactionId: params.paymentDetails.transactionId,
              metadata: params.paymentDetails,
              version: { increment: 1 },
              paidAt: new Date(),
              webhookProcessedAt: new Date()
            }
          })

          if (!updatedPayment) {
            throw new DomainError('CONCURRENT_MODIFICATION', 'تم معالجة الدفع مسبقاً')
          }

          await tx.booking.update({
            where: { id: payment.bookingId },
            data: {
              status: BOOKING_STATUS.CONFIRMED,
              paymentStatus: PAYMENT_STATUS.PAID,
              confirmedAt: new Date()
            }
          })

          await tx.slot.update({
            where: { id: payment.booking.slotId },
            data: {
              status: SLOT_STATUS.BOOKED,
              lockedById: null,
              lockedUntil: null
            }
          })

          return { success: true, paymentId: payment.id, booking: payment.booking }
        } else {
          // ❌ فشل الدفع
          await tx.payment.update({
            where: { id: payment.id },
            data: {
              status: PAYMENT_STATUS.FAILED,
              metadata: params.paymentDetails,
              errorMessage: 'Payment failed via webhook',
              version: { increment: 1 }
            }
          })

          await tx.booking.update({
            where: { id: payment.bookingId },
            data: {
              status: BOOKING_STATUS.FAILED,
              paymentStatus: PAYMENT_STATUS.FAILED
            }
          })

          await tx.slot.update({
            where: { id: payment.booking.slotId },
            data: { 
              status: SLOT_STATUS.AVAILABLE,
              lockedById: null,
              lockedUntil: null
            }
          })

          return { success: false, paymentId: payment.id, booking: payment.booking }
        }
      }, {
        isolationLevel: 'Serializable',
        maxWait: 5000,
        timeout: 10000
      })

      // 🔴 4. تحديث Webhook Idempotency
      if (transactionResult.success) {
        await WebhookIdempotencyService.markSuccess({
          providerOrderId: params.paymentDetails.orderId,
          paymentId: transactionResult.paymentId
        })
      } else {
        await WebhookIdempotencyService.markFailure({
          providerOrderId: params.paymentDetails.orderId,
          errorMessage: 'Payment failed'
        })
      }

      // 🔴 5. Side Effects بعد نجاح الـ Transaction
      if (transactionResult.success && transactionResult.booking) {
        await this.sendPostTransactionNotifications(
          transactionResult.booking,
          true,
          params.paymentDetails
        )
      }

      bookingLogger.info({
        msg: 'Booking completed successfully',
        requestId,
        bookingId: params.bookingId,
        paymentId: transactionResult.paymentId,
        success: params.success,
        durationMs: Date.now() - startTime
      })

      return { success: true, paymentId: transactionResult.paymentId }

    } catch (error: any) {
      bookingLogger.error({
        msg: 'Booking completion failed',
        requestId,
        error: error.message,
        bookingId: params.bookingId,
        durationMs: Date.now() - startTime,
        stack: error.stack
      })
      
      if (error instanceof DomainError) {
        throw error
      }
      throw new DomainError('INTERNAL_ERROR', 'فشل في إكمال الحجز')
    }
  }

  /**
   * 🧹 4. تنظيف الحجوزات المنتهية
   */
  static async cleanupExpiredBookings() {
    const startTime = Date.now()
    const jobId = `cleanup_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

    bookingLogger.info({
      msg: 'Starting expired bookings cleanup',
      jobId
    })

    try {
      const now = new Date()
      
      const expiredBookings = await prisma.booking.findMany({
        where: {
          status: BOOKING_STATUS.DRAFT,
          expiresAt: { lt: now }
        },
        include: { slot: true }
      })

      bookingLogger.info({
        msg: `Found ${expiredBookings.length} expired bookings`,
        jobId
      })

      let cleaned = 0

      for (const booking of expiredBookings) {
        try {
          await prisma.$transaction(async (tx: any) => {
            await tx.booking.update({
              where: { id: booking.id },
              data: {
                status: BOOKING_STATUS.EXPIRED,
                paymentStatus: PAYMENT_STATUS.FAILED
              }
            })

            await tx.slot.update({
              where: { id: booking.slotId },
              data: { 
                status: SLOT_STATUS.AVAILABLE,
                lockedById: null,
                lockedUntil: null
              }
            })

            cleaned++
          })

          // إشعار المستخدم
          await notificationService.send({
            userId: booking.userId,
            type: 'BOOKING_EXPIRED',
            title: 'انتهت صلاحية الحجز',
            message: 'انتهت صلاحية حجزك، يرجى المحاولة مرة أخرى',
            relatedId: booking.id
          })

        } catch (error: any) {
          bookingLogger.error({
            msg: `Failed to clean up booking ${booking.id}`,
            jobId,
            error: error.message
          })
        }
      }

      bookingLogger.info({
        msg: 'Cleanup completed',
        jobId,
        cleaned,
        durationMs: Date.now() - startTime
      })

      return { success: true, cleaned }

    } catch (error: any) {
      bookingLogger.error({
        msg: 'Cleanup job failed',
        jobId,
        error: error.message,
        durationMs: Date.now() - startTime
      })
      
      return { success: false, error: error.message }
    }
  }

  /**
   * 🔓 5. تنظيف السلات المقفولة المنتهية
   */
  static async cleanupExpiredLocks() {
    const startTime = Date.now()
    const jobId = `unlock_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

    bookingLogger.info({
      msg: 'Starting expired locks cleanup',
      jobId
    })

    try {
      const now = new Date()
      
      const result = await prisma.slot.updateMany({
        where: {
          status: SLOT_STATUS.TEMP_LOCKED,
          lockedUntil: { lt: now }
        },
        data: {
          status: SLOT_STATUS.AVAILABLE,
          lockedById: null,
          lockedUntil: null
        }
      })

      bookingLogger.info({
        msg: 'Locks cleanup completed',
        jobId,
        unlockedSlots: result.count,
        durationMs: Date.now() - startTime
      })

      return { success: true, unlockedSlots: result.count }

    } catch (error: any) {
      bookingLogger.error({
        msg: 'Locks cleanup failed',
        jobId,
        error: error.message,
        durationMs: Date.now() - startTime
      })
      
      return { success: false, error: error.message }
    }
  }

  /**
   * 🔒 Private helpers
   */

  private static async sendPostTransactionNotifications(
    booking: any,
    success: boolean,
    paymentDetails: any
  ): Promise<void> {
    try {
      if (success) {
        await notificationService.send({
          userId: booking.userId,
          type: 'PAYMENT_SUCCESS',
          title: 'تم الدفع بنجاح',
          message: `تم تأكيد حجزك في ${booking.field.name} بتاريخ ${new Date(booking.slot.startTime).toLocaleDateString('ar-EG')}`,
          relatedId: booking.id,
          data: {
            amount: paymentDetails.amount,
            fieldName: booking.field.name,
            date: booking.slot.startTime
          }
        })
      } else {
        await notificationService.send({
          userId: booking.userId,
          type: 'PAYMENT_FAILED',
          title: 'فشل الدفع',
          message: 'فشلت عملية الدفع، يرجى المحاولة مرة أخرى',
          relatedId: booking.id
        })
      }
    } catch (error: any) {
      bookingLogger.error({
        msg: 'Failed to send notifications',
        error: error.message,
        bookingId: booking.id
      })
      // لا ترمي error - notifications فشلت لكن العملية نجحت
    }
  }

  private static canBookDirectly(start: Date): boolean {
    const diffMs = start.getTime() - Date.now()
    const diffHours = diffMs / (1000 * 60 * 60)
    return diffHours >= 24
  }
}

