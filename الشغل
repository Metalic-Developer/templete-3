import { NextRequest } from 'next/server'
import { BookingOrchestrator } from '@/lib/application/services/booking-orchestrator'
import { paymobService } from '@/lib/infrastructure/payments/providers'
import { apiErrorHandler } from '@/lib/shared/api/api-error-handler'
import { logger } from '@/lib/shared/logger'

export async function POST(request: NextRequest) {
  const webhookId = `webhook_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`

  try {
    logger.info({
      webhookId,
      ip: request.headers.get('x-forwarded-for') || 'unknown',
      userAgent: request.headers.get('user-agent') || 'unknown',
      msg: 'Processing Paymob webhook'
    })

    const body = await request.json()
    const hmac = request.headers.get('hmac')

    if (!hmac) {
      logger.error({
        webhookId,
        headers: Object.fromEntries(request.headers.entries()),
        msg: 'HMAC header missing'
      })
      return apiErrorHandler(new Error('HMAC header missing'))
    }

    // 1️⃣ التحقق من HMAC باستخدام PaymobService فقط
    if (!paymobService.verifyHMAC(body.obj, hmac)) {
      logger.error({
        webhookId,
        hmacLength: hmac.length,
        bodyHash: JSON.stringify(body.obj).length,
        msg: 'Invalid HMAC signature'
      })
      return apiErrorHandler(new Error('Invalid HMAC signature'))
    }

    // 2️⃣ استخراج البيانات
    const {
      success,
      amount_cents,
      id: transactionId,
      order: { id: orderId, merchant_order_id: bookingId },
      created_at,
      currency = 'EGP'
    } = body.obj

    // 🔴 إصلاح: استخدام دالة محسنة لتحويل التاريخ
    const timestampResult = paymobService.validateWebhookTimestamp(created_at)
    const createdAt = timestampResult.date
    
    const now = new Date()
    let minutesDiff = 0
    
    if (createdAt && !isNaN(createdAt.getTime())) {
      minutesDiff = Math.floor((now.getTime() - createdAt.getTime()) / (1000 * 60))
    }

    logger.info({
      webhookId,
      bookingId,
      orderId,
      transactionId,
      success,
      amount: amount_cents / 100,
      created_at: createdAt?.toISOString() || created_at,
      minutesAgo: minutesDiff,
      currency,
      msg: 'Webhook data extracted'
    })

    // 🔴 إصلاح: لا تتجاهل webhook أبداً إذا كان HMAC صحيح
    // فقط تسجيل تحذير إذا كان قديماً
    if (minutesDiff > 60) {
      logger.warn({
        webhookId,
        minutesDiff,
        created_at: createdAt?.toISOString() || created_at,
        received_at: now.toISOString(),
        msg: 'Webhook is old but will be processed (HMAC valid)'
      })
      // 🔴 الاستمرار في المعالجة بدلاً من تجاهل
    }

    // 3️⃣ معالجة الحجز
    const processingStart = Date.now()

    const result = await BookingOrchestrator.completeBooking({
      bookingId,
      success: Boolean(success),
      paymentDetails: {
        transactionId: transactionId.toString(),
        orderId: orderId.toString(),
        amount: amount_cents / 100,
        currency
      }
    })

    const processingTime = Date.now() - processingStart

    logger.info({
      webhookId,
      bookingId,
      success,
      processingTime,
      totalTimeFromCreation: minutesDiff + processingTime / 60000,
      paymentId: result.paymentId,
      msg: 'Booking processing completed'
    })

    return new Response('OK', {
      status: 200,
      headers: {
        'Content-Type': 'text/plain',
        'X-Webhook-ID': webhookId,
        'X-Processing-Time': processingTime.toString(),
        'X-Booking-ID': bookingId,
        'X-Payment-ID': result.paymentId || '',
        'X-Webhook-Age-Minutes': minutesDiff.toString()
      }
    })
  } catch (error: any) {
    logger.error({
      msg: 'Webhook processing error',
      error: error.message,
      stack: error.stack,
      webhookId,
      url: request.url
    })

    // 🔴 إضافة: تصنيف الأخطاء
    const isDuplicate = error.message?.includes('PAYMENT_ALREADY_PROCESSED') || 
                       error.message?.includes('تم معالجة الدفع مسبقاً')
    
    const isAmountMismatch = error.message?.includes('تطابق المبلغ')
    
    const status = isDuplicate ? 409 : isAmountMismatch ? 400 : 500

    return new Response(error.message || 'ERROR', {
      status,
      headers: {
        'Content-Type': 'text/plain',
        'X-Webhook-Status': isDuplicate ? 'DUPLICATE' : isAmountMismatch ? 'AMOUNT_MISMATCH' : 'ERROR',
        'X-Error-Message': error.message?.substring(0, 100) || ''
      }
    })
  }
}
