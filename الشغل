// lib/shared/api/api-error-handler.ts
import { NextResponse } from 'next/server'
import { DomainError } from '@/lib/core/errors/domain-errors'
import { ERROR_CODES } from '@/lib/core/errors/error-codes'

export function apiErrorHandler(error: unknown): NextResponse {
  console.error('API Error:', error)

  // Handle DomainError
  if (error instanceof DomainError) {
    const status = getHttpStatus(error.code)
    return NextResponse.json(
      {
        error: true,
        code: ERROR_CODES[error.code],
        message: error.message,
        details: error.details
      },
      { status }
    )
  }

  // Handle Zod validation errors
  if (error instanceof Error && error.name === 'ZodError') {
    return NextResponse.json(
      {
        error: true,
        code: 'VALIDATION_ERROR',
        message: 'بيانات غير صالحة',
        details: error.message
      },
      { status: 400 }
    )
  }

  // Handle Prisma errors
  if (error instanceof Error && error.name.includes('Prisma')) {
    return NextResponse.json(
      {
        error: true,
        code: 'DATABASE_ERROR',
        message: 'حدث خطأ في قاعدة البيانات'
      },
      { status: 500 }
    )
  }

  // Default error
  return NextResponse.json(
    {
      error: true,
      code: 'INTERNAL_SERVER_ERROR',
      message: 'حدث خطأ غير متوقع'
    },
    { status: 500 }
  )
}

function getHttpStatus(errorCode: keyof typeof ERROR_CODES): number {
  const code = ERROR_CODES[errorCode]
  
  if (code.startsWith('AUTH')) return 401
  if (code.startsWith('VAL')) return 400
  if (code.startsWith('SLOT') || code.startsWith('BOOK') || code.startsWith('PAY')) return 400
  if (code.startsWith('FIELD')) return 404
  return 500
}
// lib/infrastructure/webhooks/webhook-idempotency-service.ts
import { prisma } from '@/lib/infrastructure/database/prisma'
import { webhookLogger } from '@/lib/shared/logger'

export class WebhookIdempotencyService {
  /**
   * 🔐 بدء معالجة Webhook مع Idempotency
   */
  static async beginProcessing(params: {
    providerOrderId: string
    providerTransactionId: string
    paymentId?: string
  }): Promise<{ shouldProcess: boolean; existingRecord?: any }> {
    try {
      // 🔴 التحقق من المعالجة المسبقة
      const existing = await prisma.webhookProcessing.findUnique({
        where: { providerOrderId: params.providerOrderId },
        include: { payment: true }
      })

      if (existing) {
        // إذا كانت ناجحة مسبقاً
        if (existing.status === 'SUCCESS') {
          webhookLogger.info({
            msg: 'Webhook already processed successfully',
            providerOrderId: params.providerOrderId,
            paymentId: existing.paymentId
          })
          return { shouldProcess: false, existingRecord: existing }
        }

        // إذا كانت فاشلة ولكن أقل من 3 محاولات
        if (existing.status === 'FAILED' && existing.attempts < 3) {
          await prisma.webhookProcessing.update({
            where: { id: existing.id },
            data: {
              status: 'PROCESSING',
              attempts: { increment: 1 },
              lastAttemptAt: new Date()
            }
          })
          return { shouldProcess: true }
        }

        // إذا تجاوزت الحد الأقصى للمحاولات
        return { shouldProcess: false, existingRecord: existing }
      }

      // 🔴 إنشاء سجل جديد
      await prisma.webhookProcessing.create({
        data: {
          providerOrderId: params.providerOrderId,
          providerTransactionId: params.providerTransactionId,
          paymentId: params.paymentId,
          status: 'PROCESSING',
          attempts: 1,
          lastAttemptAt: new Date()
        }
      })

      return { shouldProcess: true }

    } catch (error: any) {
      webhookLogger.error({
        msg: 'Webhook processing start failed',
        error: error.message,
        params
      })
      
      // في حالة الخطأ، نسمح بالمعالجة
      return { shouldProcess: true }
    }
  }

  /**
   * ✅ تسجيل نجاح معالجة Webhook
   */
  static async markSuccess(params: {
    providerOrderId: string
    paymentId: string
  }) {
    try {
      await prisma.webhookProcessing.update({
        where: { providerOrderId: params.providerOrderId },
        data: {
          status: 'SUCCESS',
          paymentId: params.paymentId,
          processedAt: new Date()
        }
      })

      webhookLogger.info({
        msg: 'Webhook marked as successful',
        providerOrderId: params.providerOrderId,
        paymentId: params.paymentId
      })

    } catch (error: any) {
      webhookLogger.error({
        msg: 'Failed to mark webhook as successful',
        error: error.message,
        params
      })
    }
  }

  /**
   * ❌ تسجيل فشل معالجة Webhook
   */
  static async markFailure(params: {
    providerOrderId: string
    errorMessage: string
  }) {
    try {
      await prisma.webhookProcessing.update({
        where: { providerOrderId: params.providerOrderId },
        data: {
          status: 'FAILED',
          errorMessage: params.errorMessage,
          lastAttemptAt: new Date()
        }
      })

      webhookLogger.warn({
        msg: 'Webhook marked as failed',
        providerOrderId: params.providerOrderId,
        errorMessage: params.errorMessage
      })

    } catch (error: any) {
      webhookLogger.error({
        msg: 'Failed to mark webhook as failed',
        error: error.message,
        params
      })
    }
  }

  /**
   * 🔍 التحقق من حالة Webhook
   */
  static async getStatus(providerOrderId: string) {
    try {
      const record = await prisma.webhookProcessing.findUnique({
        where: { providerOrderId },
        include: { payment: true }
      })

      return record
    } catch (error: any) {
      webhookLogger.error({
        msg: 'Failed to get webhook status',
        error: error.message,
        providerOrderId
      })
      return null
    }
  }
}
