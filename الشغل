import { prisma } from '@/lib/infrastructure/database/prisma'
import { startOfDay, addDays } from 'date-fns'
import { DomainError } from '@/lib/core/errors/domain-errors'
import { BOOKING_STATUS } from '@/lib/shared/constants'

type BookingWithSlot = {
  slot: {
    startTime: Date
    endTime: Date
    durationMinutes: number | null
  }
}

export async function checkBookingLimits({
  userId,
  slotDate,
  slotDurationMin
}: {
  userId: string
  slotDate: Date
  slotDurationMin: number
}) {
  const dayStart = startOfDay(slotDate)
  const dayEnd = addDays(dayStart, 1)

  const dayOfWeek = dayStart.getDay()
  const weekStart = addDays(dayStart, -dayOfWeek)
  const weekEnd = addDays(weekStart, 7)

  const dailyBookings: BookingWithSlot[] = await prisma.booking.findMany({
    where: {
      userId,
      status: {
        in: [BOOKING_STATUS.CONFIRMED, BOOKING_STATUS.PENDING_PAYMENT]
      },
      slot: {
        startTime: { gte: dayStart, lt: dayEnd }
      }
    },
    include: {
      slot: {
        select: {
          startTime: true,
          endTime: true,
          durationMinutes: true
        }
      }
    }
  })

  const dailyMinutes = dailyBookings.reduce((sum: number, booking: BookingWithSlot) => {
    if (booking.slot.durationMinutes) {
      return sum + booking.slot.durationMinutes
    }
    const start = new Date(booking.slot.startTime)
    const end = new Date(booking.slot.endTime)
    const diffMinutes = Math.round((end.getTime() - start.getTime()) / (1000 * 60))
    return sum + diffMinutes
  }, 0)

  if (dailyMinutes + slotDurationMin > 120) {
    throw new DomainError('BOOKING_LIMIT_EXCEEDED', 'وصلت للحد الأقصى اليومي (ساعتين)')
  }

  const weeklyBookings: BookingWithSlot[] = await prisma.booking.findMany({
    where: {
      userId,
      status: {
        in: [BOOKING_STATUS.CONFIRMED, BOOKING_STATUS.PENDING_PAYMENT]
      },
      slot: {
        startTime: { gte: weekStart, lt: weekEnd }
      }
    },
    include: {
      slot: {
        select: {
          startTime: true,
          endTime: true,
          durationMinutes: true
        }
      }
    }
  })

  const weeklyMinutes = weeklyBookings.reduce((sum: number, booking: BookingWithSlot) => {
    if (booking.slot.durationMinutes) {
      return sum + booking.slot.durationMinutes
    }
    const start = new Date(booking.slot.startTime)
    const end = new Date(booking.slot.endTime)
    const diffMinutes = Math.round((end.getTime() - start.getTime()) / (1000 * 60))
    return sum + diffMinutes
  }, 0)

  if (weeklyMinutes + slotDurationMin > 240) {
    throw new DomainError('BOOKING_LIMIT_EXCEEDED', 'وصلت للحد الأقصى الأسبوعي (4 ساعات)')
  }

  return true
}
// lib/domain/guards/slot-guards.ts
import { prisma } from '@/lib/infrastructure/database/prisma'
import { DomainError } from '@/lib/core/errors/domain-errors'
import { SLOT_STATUS } from '@/lib/shared/constants'
import { StateTransitionValidator } from '@/lib/application/services/booking-transitions'

export class SlotStateGuard {
  static async assertCanBeLocked(params: {
    slotId: string
    userId: string
    fieldId: string
  }) {
    const slot = await prisma.slot.findUnique({
      where: { id: params.slotId },
      include: { field: true }
    })

    if (!slot) {
      throw new DomainError('SLOT_NOT_FOUND')
    }

    if (slot.fieldId !== params.fieldId) {
      throw new DomainError('SLOT_NOT_FOUND', 'الموعد لا ينتمي لهذا الملعب')
    }

    const now = new Date()

    if (slot.status === SLOT_STATUS.BOOKED) {
      throw new DomainError('SLOT_ALREADY_BOOKED')
    }

    // إصلاح: استخدام المقارنة الصحيحة
    if (slot.status === SLOT_STATUS.UNAVAILABLE) {
      throw new DomainError('SLOT_UNAVAILABLE')
    }

    if (new Date(slot.startTime) <= now) {
      throw new DomainError('TIME_IN_PAST')
    }

    if (slot.status === SLOT_STATUS.TEMP_LOCKED && slot.lockedUntil && slot.lockedUntil > now) {
      if (slot.lockedById === params.userId) {
        return { slot, canExtend: true }
      } else {
        throw new DomainError('SLOT_LOCKED_BY_OTHER')
      }
    }

    return { slot, canExtend: false }
  }

  static async assertIsLockedToUser(params: {
    slotId: string
    userId: string
  }) {
    const slot = await prisma.slot.findUnique({
      where: { id: params.slotId }
    })

    if (!slot) {
      throw new DomainError('SLOT_NOT_FOUND')
    }

    const now = new Date()

    // إصلاح: استخدام المقارنة الصحيحة مع الثابت
    if (slot.status !== SLOT_STATUS.TEMP_LOCKED) {
      throw new DomainError('SLOT_CANNOT_BE_LOCKED', 'الموعد غير مقفول')
    }

    if (!slot.lockedUntil || slot.lockedUntil <= now) {
      throw new DomainError('SLOT_LOCK_EXPIRED')
    }

    if (slot.lockedById !== params.userId) {
      throw new DomainError('SLOT_LOCKED_BY_OTHER')
    }

    return slot
  }

  static async assertCanTransition(params: {
    slotId: string
    targetStatus: string
    userId?: string
  }) {
    const slot = await prisma.slot.findUnique({
      where: { id: params.slotId }
    })

    if (!slot) {
      throw new DomainError('SLOT_NOT_FOUND')
    }

    // استخدام الـ validator الجديد الذي يرمي DomainError
    StateTransitionValidator.validateSlotTransition(
      slot.status,
      params.targetStatus,
      params.userId,
      slot
    )

    return slot
  }

  static async cleanupExpiredLocks() {
    const now = new Date()
    
    const result = await prisma.slot.updateMany({
      where: {
        status: SLOT_STATUS.TEMP_LOCKED,
        lockedUntil: { lt: now }
      },
      data: {
        status: SLOT_STATUS.AVAILABLE,
        lockedById: null,
        lockedUntil: null
      }
    })

    return result.count
  }
}

export const assertSlotCanLock = SlotStateGuard.assertCanBeLocked.bind(SlotStateGuard)
export const assertSlotLocked = SlotStateGuard.assertIsLockedToUser.bind(SlotStateGuard)
export const assertSlotTransition = SlotStateGuard.assertCanTransition.bind(SlotStateGuard)
// lib/domain/guards/payment-guards.ts
import { prisma } from '@/lib/infrastructure/database/prisma'
import { DomainError } from '@/lib/core/errors/domain-errors'
import { 
  PAYMENT_STATUS, 
  BOOKING_STATUS,
  SLOT_STATUS
} from '@/lib/shared/constants'
import { BookingStateMachine } from '@/lib/core/state-machines/booking-state-machine'

export class PaymentStateGuard {
  /**
   * 🔴 المصدر الوحيد لتحقق من إمكانية معالجة الدفع
   */
  static async assertCanProcessPayment(params: {
    bookingId: string
    userId: string
  }) {
    const booking = await prisma.booking.findUnique({
      where: { id: params.bookingId },
      include: {
        slot: true,
        payments: {
          where: { 
            OR: [
              { status: PAYMENT_STATUS.PROCESSING },
              { status: PAYMENT_STATUS.PAID }
            ]
          },
          orderBy: { createdAt: 'desc' },
          take: 1
        }
      }
    })

    if (!booking) throw new DomainError('BOOKING_NOT_FOUND')
    if (booking.userId !== params.userId) throw new DomainError('BOOKING_NOT_OWNED')

    // 🔴 استخدام State Machine
    if (![BOOKING_STATUS.DRAFT, BOOKING_STATUS.PENDING_PAYMENT].includes(booking.status as BOOKING_STATUS)) {
      throw new DomainError(
        'BOOKING_INVALID_STATE',
        `لا يمكن الدفع لحجز بحالة ${booking.status}. المسموح: DRAFT أو PENDING_PAYMENT`
      )
    }

    if (booking.expiresAt && booking.expiresAt < new Date()) {
      throw new DomainError('BOOKING_EXPIRED')
    }

    // 🔴 تحقق من حالة Slot باستخدام State Machine
    const slotTransition = BookingStateMachine.validateSlotTransition(
      booking.slot.status,
      SLOT_STATUS.TEMP_LOCKED
    )
    if (!slotTransition.valid) {
      throw new DomainError('SLOT_LOCK_EXPIRED', slotTransition.reason)
    }

    if (booking.slot.lockedById !== params.userId) {
      throw new DomainError('SLOT_LOCKED_BY_OTHER')
    }

    // 🔴 تحقق من وجود دفع ناجح مسبقاً
    const lastPayment = booking.payments[0]
    if (lastPayment?.status === PAYMENT_STATUS.PAID) {
      throw new DomainError('PAYMENT_ALREADY_PROCESSED')
    }

    return { booking, lastPayment }
  }

  /**
   * 🔴 المصدر الوحيد لتحقق Webhook
   */
  static async assertWebhookValid(params: {
    providerOrderId: string
    transactionId: string
    amount: number
  }) {
    const payment = await prisma.payment.findFirst({
      where: { 
        providerOrderId: params.providerOrderId,
        OR: [
          { status: PAYMENT_STATUS.PROCESSING },
          { status: PAYMENT_STATUS.PENDING }
        ]
      },
      include: { 
        booking: {
          include: {
            slot: true,
            user: true,
            payments: {
              where: { status: PAYMENT_STATUS.PAID },
              take: 1
            }
          }
        }
      }
    })

    if (!payment) {
      throw new DomainError('PAYMENT_NOT_FOUND', `لم يتم العثور على دفعة ب orderId: ${params.providerOrderId}`)
    }

    // 🔴 تحقق من عدم تكرار المعالجة
    const paidPayment = payment.booking.payments[0]
    if (paidPayment) {
      throw new DomainError('PAYMENT_ALREADY_PROCESSED', `تم معالجة هذه الدفعة مسبقاً`)
    }

    // 🔴 تحقق من تطابق المبلغ مع tolerance
    const amountDiff = Math.abs(params.amount - Number(payment.amount))
    if (amountDiff > 0.01) {
      throw new DomainError('PAYMENT_FAILED',
        `المبلغ غير متطابق: المتوقع ${payment.amount}، المستلم ${params.amount}`
      )
    }

    // 🔴 تحقق من حالة الحجز باستخدام State Machine
    const bookingTransition = BookingStateMachine.validateBookingTransition(
      payment.booking.status,
      BOOKING_STATUS.CONFIRMED,
      { paymentStatus: PAYMENT_STATUS.PAID }
    )
    if (!bookingTransition.valid) {
      throw new DomainError('BOOKING_INVALID_STATE', bookingTransition.reason)
    }

    return payment
  }

  /**
   * 🔴 المصدر الوحيد لتحقق تحديث الدفع
   */
  static async assertCanUpdatePayment(params: {
    paymentId: string
    targetStatus: string
    version: number
  }) {
    const payment = await prisma.payment.findUnique({
      where: { id: params.paymentId },
      include: { booking: true }
    })

    if (!payment) throw new DomainError('PAYMENT_NOT_FOUND')

    // 🔴 تحقق من Optimistic Locking
    if (payment.version !== params.version) {
      throw new DomainError('CONCURRENT_MODIFICATION', 'تم تعديل الدفعة بواسطة عملية أخرى')
    }

    // 🔴 استخدام State Machine
    const transition = BookingStateMachine.validatePaymentTransition(
      payment.status,
      params.targetStatus
    )
    if (!transition.valid) {
      throw new DomainError('INVALID_PAYMENT_TRANSITION', transition.reason)
    }

    return payment
  }
}

