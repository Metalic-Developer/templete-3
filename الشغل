// lib/application/idempotency/idempotency-guard.ts
import { prisma } from '@/lib/infrastructure/database/prisma'
import crypto from 'crypto'
import { idempotencyLogger } from '@/lib/shared/logger'

export class IdempotencyGuard {
  /**
   * 🔐 توليد مفتاح باستخدام Database Time بدل Date.now()
   */
  static generateKey(prefix: string = 'req'): string {
    const timestamp = this.getDatabaseTimestamp()
    const random = crypto.randomBytes(16).toString('hex')
    const serverId = process.env.SERVER_ID || 'server1'
    return `${prefix}_${serverId}_${timestamp}_${random}`
  }

  /**
   * 🔐 تأكد من أن العملية idempotent
   */
  static async check(
    key: string,
    userId: string,
    method: string,
    requestData?: any
  ): Promise<{
    idempotent: boolean
    response?: any
    shouldProceed: boolean
  }> {
    try {
      // 🔴 استخدام Database Time للتأكد من التزامن
      const dbTime = await this.getDatabaseTime()
      
      // تنظيف المفاتيح المنتهية باستخدام Database Time
      await prisma.idempotencyKey.deleteMany({
        where: { expiresAt: { lt: dbTime } }
      }).catch(() => {
        // تجاهل الأخطاء في التنظيف
      })

      // البحث عن المفتاح
      const existing = await prisma.idempotencyKey.findFirst({
        where: { 
          AND: [
            { key },
            { userId }
          ]
        }
      })

      if (!existing) {
        return { idempotent: false, shouldProceed: true }
      }

      if (existing.method !== method) {
        throw new Error('مفتاح idempotency غير صالح لهذا العملية')
      }

      // التحقق من requestHash
      if (requestData && existing.requestHash) {
        const currentHash = this.hashRequest(requestData)
        if (currentHash !== existing.requestHash) {
          throw new Error('طلب مكرر بمعطيات مختلفة')
        }
      }

      // إذا كان هناك response مخزن
      if (existing.response) {
        idempotencyLogger.info({
          msg: 'Idempotent request detected',
          key,
          userId,
          method
        })
        
        return {
          idempotent: true,
          response: existing.response,
          shouldProceed: false
        }
      }

      // المفتاح موجود ولكن بدون response (مازال يعمل)
      return { idempotent: true, shouldProceed: false }

    } catch (error: any) {
      idempotencyLogger.error({
        msg: 'Idempotency check error',
        error: error.message,
        key,
        userId
      })
      return { idempotent: false, shouldProceed: true }
    }
  }

  /**
   * 💾 حفظ نتيجة idempotent باستخدام Database Time
   */
  static async saveResponse(
    key: string,
    userId: string,
    method: string,
    response: any,
    requestData?: any,
    ttlMinutes: number = 60
  ) {
    const requestHash = requestData ? this.hashRequest(requestData) : ''
    
    try {
      // 🔴 استخدام Database Time للـ expiresAt
      const dbTime = await this.getDatabaseTime()
      const expiresAt = new Date(dbTime.getTime() + ttlMinutes * 60 * 1000)

      return await prisma.idempotencyKey.upsert({
        where: {
          key_userId: {
            key,
            userId
          }
        },
        update: {
          response,
          expiresAt
        },
        create: {
          key,
          userId,
          method,
          requestHash,
          response,
          expiresAt
        }
      })
    } catch (error: any) {
      idempotencyLogger.error({
        msg: 'Failed to save idempotency response',
        error: error.message,
        key,
        userId
      })
      return null
    }
  }

  /**
   * 🔢 الحصول على Database Time للتزامن
   */
  private static async getDatabaseTime(): Promise<Date> {
    try {
      // استعلام للحصول على وقت قاعدة البيانات
      const result = await prisma.$queryRaw`SELECT NOW() as db_time`
      return (result as any)[0].db_time
    } catch {
      // Fallback لـ local time إذا فشل الاستعلام
      return new Date()
    }
  }

  /**
   * 🔢 الحصول على timestamp متزامن
   */
  private static getDatabaseTimestamp(): string {
    // استخدام process.hrtime() للحصول على timestamp عالي الدقة
    const hrtime = process.hrtime()
    return `${Date.now()}_${hrtime[0]}_${hrtime[1]}`
  }

  /**
   * 🔐 حساب هاش للطلب
   */
  private static hashRequest(data: any): string {
    const str = JSON.stringify(data, Object.keys(data).sort())
    return crypto.createHash('sha256').update(str).digest('hex')
  }
}
