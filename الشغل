import { NextRequest, NextResponse } from 'next/server'
import { getServerSession } from 'next-auth'
import { authOptions } from '@/lib/infrastructure/auth/auth-options'
import { BookingOrchestrator } from '@/lib/application/services/booking-orchestrator'
import { apiErrorHandler } from '@/lib/shared/api/api-error-handler'
import { logger } from '@/lib/shared/logger'

export async function POST(request: NextRequest) {
  const requestId = `create_payment_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`
  
  try {
    logger.info({ 
      msg: 'Creating payment',
      requestId 
    })

    const session = await getServerSession(authOptions)
    const userId = session?.user?.id

    if (!userId) {
      logger.warn({ 
        msg: 'Unauthorized payment attempt',
        requestId 
      })
      return NextResponse.json(
        { error: 'يجب تسجيل الدخول أولاً' },
        { status: 401 }
      )
    }

    const { bookingId, amount, currency = 'EGP', idempotencyKey } = await request.json()

    if (!bookingId || !amount) {
      logger.warn({ 
        msg: 'Incomplete payment data',
        requestId, 
        bookingId, 
        amount 
      })
      return NextResponse.json(
        { error: 'بيانات الدفع غير مكتملة' },
        { status: 400 }
      )
    }

    if (amount <= 0) {
      logger.warn({ 
        msg: 'Invalid payment amount',
        requestId, 
        amount 
      })
      return NextResponse.json(
        { error: 'قيمة الدفع غير صالحة' },
        { status: 400 }
      )
    }

    // 🔴 إضافة: تحقق من حدود المبلغ
    const MAX_AMOUNT = 10000
    if (amount > MAX_AMOUNT) {
      logger.warn({ 
        msg: 'Payment amount exceeds limit',
        requestId, 
        amount,
        maxAmount: MAX_AMOUNT 
      })
      return NextResponse.json(
        { error: `لا يمكن تجاوز مبلغ ${MAX_AMOUNT} جنيه` },
        { status: 400 }
      )
    }

    const result = await BookingOrchestrator.initiatePayment({
      bookingId,
      amount,
      currency,
      idempotencyKey,
      userId,
    })

    logger.info({
      requestId,
      bookingId,
      orderId: result.orderId,
      internalPaymentId: result.internalPaymentId,
      userId,
      msg: 'Payment initiated successfully'
    })

    return NextResponse.json({
      success: true,
      data: result,
      message: 'تم بدء عملية الدفع بنجاح'
    })

  } catch (error: any) {
    logger.error({
      msg: 'Payment creation error',
      error: error.message,
      stack: error.stack,
      requestId
    })
    return apiErrorHandler(error)
  }
}
