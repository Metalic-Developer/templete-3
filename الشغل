import { prisma } from '@/lib/infrastructure/database/prisma'
import { addMinutes } from 'date-fns'
import { 
  SLOT_STATUS, 
  BOOKING_STATUS, 
  PAYMENT_STATUS 
} from '@/lib/shared/constants'
