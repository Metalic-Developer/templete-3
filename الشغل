// lib/infrastructure/payments/providers/hmac-verifier.ts
import crypto from 'crypto'
import { ENV } from '@/lib/shared/env/env'
import { paymentLogger } from '@/lib/shared/logger'

export class PaymobHmacVerifier {
  private readonly hmacSecret: string

  constructor() {
    this.hmacSecret = ENV.PAYMOB_HMAC_SECRET || ''
    
    if (!this.hmacSecret) {
      paymentLogger.warn({
        msg: 'PAYMOB_HMAC_SECRET is not set. HMAC verification will fail.'
      })
    }
  }

  // 🔴 إصلاح: استخدام دالة آمنة للمقارنة
  verify(data: any, receivedHmac: string): boolean {
    try {
      if (!this.hmacSecret) {
        paymentLogger.error({
          msg: 'HMAC verification failed - secret not configured'
        })
        return false
      }

      const calculatedHmac = this.calculateHMAC(data)
      
      // 🔴 إصلاح: استخدام مقارنة آمنة
      const isValid = this.safeCompare(calculatedHmac, receivedHmac)

      paymentLogger.info({
        msg: 'HMAC verification completed',
        isValid,
        orderId: data.order?.id,
        method: 'hmac-verifier'
      })
      
      return isValid
    } catch (error: any) {
      paymentLogger.error({
        msg: 'HMAC verification error',
        error: error.message,
        dataKeys: Object.keys(data).join(',')
      })
      return false
    }
  }

  // 🔴 إضافة: دالة آمنة للمقارنة
  private safeCompare(expected: string, actual: string): boolean {
    try {
      if (expected.length !== actual.length) {
        return false
      }
      
      let result = 0
      for (let i = 0; i < expected.length; i++) {
        result |= expected.charCodeAt(i) ^ actual.charCodeAt(i)
      }
      return result === 0
    } catch {
      return false
    }
  }

  // نفس منطق PaymobService تماماً
  private calculateHMAC(data: any): string {
    const hmacString = [
      data.amount_cents || '',
      data.created_at || '',
      data.currency || '',
      data.error_occured || '',
      data.has_parent_transaction || '',
      data.id || '',
      data.integration_id || '',
      data.is_3d_secure || '',
      data.is_auth || '',
      data.is_capture || '',
      data.is_refunded || '',
      data.is_standalone_payment || '',
      data.is_voided || '',
      data.order?.id || '',
      data.owner || '',
      data.pending || '',
      (data.source_data?.pan || '') + (data.source_data?.sub_type || '') + (data.source_data?.type || ''),
      data.success || ''
    ].join('')
    
    return crypto
      .createHmac('sha512', this.hmacSecret)
      .update(hmacString)
      .digest('hex')
  }

  // 🔴 إضافة: تحقق من مقدار الوقت
  isFresh(timestamp: number | string, maxAgeSeconds: number = 300): boolean {
    try {
      let date: Date
      
      if (typeof timestamp === 'string') {
        const parsedDate = new Date(timestamp)
        if (isNaN(parsedDate.getTime())) {
          paymentLogger.warn({
            msg: 'Invalid timestamp string',
            timestamp
          })
          return true // 🔴 لا تتجاهل webhook بسبب timestamp
        }
        date = parsedDate
      } else {
        date = new Date(timestamp * 1000) // تحويل من seconds to milliseconds
      }
      
      const now = new Date()
      const ageSeconds = (now.getTime() - date.getTime()) / 1000
      
      const isFresh = ageSeconds <= maxAgeSeconds
      
      paymentLogger.debug({
        msg: 'Timestamp freshness check',
        input: timestamp,
        parsed: date.toISOString(),
        now: now.toISOString(),
        ageSeconds,
        maxAgeSeconds,
        isFresh
      })
      
      return isFresh
    } catch (error: any) {
      paymentLogger.warn({
        msg: 'Timestamp freshness check failed',
        timestamp,
        error: error.message
      })
      return true // 🔴 لا تتجاهل webhook إذا فشل التحقق
    }
  }
}

