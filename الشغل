import { 
  BOOKING_STATUS, 
  PAYMENT_STATUS,
  SLOT_STATUS 
} from '@/lib/shared/constants'

export class BookingStateMachine {
  // 🔴 تعريف انتقالات الحالات بشكل صارم
  private static readonly ALLOWED_TRANSITIONS = {
    [BOOKING_STATUS.DRAFT]: {
      to: [BOOKING_STATUS.PENDING_PAYMENT, BOOKING_STATUS.EXPIRED],
      from: [],
      description: 'الحجز المبدئي'
    },
    [BOOKING_STATUS.PENDING_PAYMENT]: {
      to: [BOOKING_STATUS.CONFIRMED, BOOKING_STATUS.FAILED, BOOKING_STATUS.CANCELLED],
      from: [BOOKING_STATUS.DRAFT],
      description: 'بانتظار الدفع'
    },
    [BOOKING_STATUS.CONFIRMED]: {
      to: [BOOKING_STATUS.COMPLETED, BOOKING_STATUS.CANCELLED],
      from: [BOOKING_STATUS.PENDING_PAYMENT],
      description: 'مؤكد'
    },
    [BOOKING_STATUS.FAILED]: {
      to: [],
      from: [BOOKING_STATUS.PENDING_PAYMENT, BOOKING_STATUS.DRAFT],
      description: 'فشل'
    },
    [BOOKING_STATUS.EXPIRED]: {
      to: [],
      from: [BOOKING_STATUS.DRAFT],
      description: 'انتهت صلاحيته'
    },
    [BOOKING_STATUS.CANCELLED]: {
      to: [],
      from: [BOOKING_STATUS.CONFIRMED, BOOKING_STATUS.PENDING_PAYMENT],
      description: 'ملغي'
    },
    [BOOKING_STATUS.COMPLETED]: {
      to: [],
      from: [BOOKING_STATUS.CONFIRMED],
      description: 'مكتمل'
    }
  }

  private static readonly PAYMENT_TRANSITIONS = {
    [PAYMENT_STATUS.PENDING]: {
      to: [PAYMENT_STATUS.PROCESSING, PAYMENT_STATUS.FAILED],
      from: []
    },
    [PAYMENT_STATUS.PROCESSING]: {
      to: [PAYMENT_STATUS.PAID, PAYMENT_STATUS.FAILED, PAYMENT_STATUS.REFUNDED],
      from: [PAYMENT_STATUS.PENDING]
    },
    [PAYMENT_STATUS.PAID]: {
      to: [PAYMENT_STATUS.REFUNDED],
      from: [PAYMENT_STATUS.PROCESSING]
    },
    [PAYMENT_STATUS.FAILED]: {
      to: [PAYMENT_STATUS.PROCESSING],
      from: [PAYMENT_STATUS.PENDING, PAYMENT_STATUS.PROCESSING]
    },
    [PAYMENT_STATUS.REFUNDED]: {
      to: [],
      from: [PAYMENT_STATUS.PAID, PAYMENT_STATUS.PROCESSING]
    }
  }

  private static readonly SLOT_TRANSITIONS = {
    [SLOT_STATUS.AVAILABLE]: {
      to: [SLOT_STATUS.TEMP_LOCKED, SLOT_STATUS.UNAVAILABLE],
      from: [SLOT_STATUS.TEMP_LOCKED, SLOT_STATUS.BOOKED]
    },
    [SLOT_STATUS.TEMP_LOCKED]: {
      to: [SLOT_STATUS.BOOKED, SLOT_STATUS.AVAILABLE],
      from: [SLOT_STATUS.AVAILABLE]
    },
    [SLOT_STATUS.BOOKED]: {
      to: [SLOT_STATUS.AVAILABLE],
      from: [SLOT_STATUS.TEMP_LOCKED]
    },
    [SLOT_STATUS.UNAVAILABLE]: {
      to: [SLOT_STATUS.AVAILABLE],
      from: [SLOT_STATUS.AVAILABLE]
    }
  }

  /**
   * ✅ التحقق من انتقال حالة الحجز
   */
  static validateBookingTransition(
    currentStatus: string,
    nextStatus: string,
    context?: any
  ): { valid: boolean; reason?: string } {
    const transition = this.ALLOWED_TRANSITIONS[currentStatus as BOOKING_STATUS]
    
    if (!transition) {
      return { valid: false, reason: `الحالة الحالية غير معروفة: ${currentStatus}` }
    }

    if (!transition.to.includes(nextStatus as BOOKING_STATUS)) {
      return { 
        valid: false, 
        reason: `لا يمكن الانتقال من ${currentStatus} إلى ${nextStatus}. المسموح: ${transition.to.join(', ')}` 
      }
    }

    // 🔴 شروط إضافية خاصة لكل انتقال
    const specificChecks = this.specificTransitionChecks(currentStatus, nextStatus, context)
    if (!specificChecks.valid) {
      return specificChecks
    }

    return { valid: true }
  }

  /**
   * ✅ التحقق من انتقال حالة الدفع
   */
  static validatePaymentTransition(
    currentStatus: string,
    nextStatus: string,
    context?: any
  ): { valid: boolean; reason?: string } {
    const transition = this.PAYMENT_TRANSITIONS[currentStatus as PAYMENT_STATUS]
    
    if (!transition) {
      return { valid: false, reason: `حالة الدفع الحالية غير معروفة: ${currentStatus}` }
    }

    if (!transition.to.includes(nextStatus as PAYMENT_STATUS)) {
      return { 
        valid: false, 
        reason: `لا يمكن الانتقال من ${currentStatus} إلى ${nextStatus}. المسموح: ${transition.to.join(', ')}` 
      }
    }

    return { valid: true }
  }

  /**
   * ✅ التحقق من انتقال حالة السلة
   */
  static validateSlotTransition(
    currentStatus: string,
    nextStatus: string,
    context?: any
  ): { valid: boolean; reason?: string } {
    const transition = this.SLOT_TRANSITIONS[currentStatus as SLOT_STATUS]
    
    if (!transition) {
      return { valid: false, reason: `حالة السلة الحالية غير معروفة: ${currentStatus}` }
    }

    if (!transition.to.includes(nextStatus as SLOT_STATUS)) {
      return { 
        valid: false, 
        reason: `لا يمكن الانتقال من ${currentStatus} إلى ${nextStatus}. المسموح: ${transition.to.join(', ')}` 
      }
    }

    return { valid: true }
  }

  /**
   * 🔴 شروط انتقالية خاصة
   */
  private static specificTransitionChecks(
    currentStatus: string,
    nextStatus: string,
    context?: any
  ): { valid: boolean; reason?: string } {
    switch (`${currentStatus}->${nextStatus}`) {
      case `${BOOKING_STATUS.PENDING_PAYMENT}->${BOOKING_STATUS.CONFIRMED}`:
        if (!context?.paymentId) {
          return { valid: false, reason: 'تأكيد الحجز يتطلب معرف الدفع' }
        }
        if (context.paymentStatus !== PAYMENT_STATUS.PAID) {
          return { valid: false, reason: 'تأكيد الحجز يتطلب دفع ناجح' }
        }
        break;

      case `${BOOKING_STATUS.DRAFT}->${BOOKING_STATUS.EXPIRED}`:
        if (!context?.expiresAt || new Date(context.expiresAt) > new Date()) {
          return { valid: false, reason: 'لا يمكن انتهاء الحجز قبل وقت انتهاء الصلاحية' }
        }
        break;

      case `${BOOKING_STATUS.CONFIRMED}->${BOOKING_STATUS.CANCELLED}`:
        const slotTime = new Date(context?.slotStartTime || 0)
        const now = new Date()
        const hoursBefore = (slotTime.getTime() - now.getTime()) / (1000 * 60 * 60)
        
        if (hoursBefore < 24) {
          return { valid: false, reason: 'لا يمكن إلغاء الحجز قبل أقل من 24 ساعة' }
        }
        break;
    }

    return { valid: true }
  }

  /**
   * 🔴 الحصول على الحالات الممكنة التالية
   */
  static getNextPossibleStates(
    currentStatus: string,
    entityType: 'booking' | 'payment' | 'slot'
  ): string[] {
    switch (entityType) {
      case 'booking':
        return this.ALLOWED_TRANSITIONS[currentStatus as BOOKING_STATUS]?.to || []
      case 'payment':
        return this.PAYMENT_TRANSITIONS[currentStatus as PAYMENT_STATUS]?.to || []
      case 'slot':
        return this.SLOT_TRANSITIONS[currentStatus as SLOT_STATUS]?.to || []
      default:
        return []
    }
  }
}
